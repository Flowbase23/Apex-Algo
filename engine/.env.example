# ============================================================
# Apex Algo Trading Engine — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your API keys.
#   cp .env.example .env
#
# NOTE: .env is in .gitignore — never commit real keys.

# --- Premium Data Sources (optional) ---
# Yahoo Finance is free and enabled by default.
# Uncomment and set these if you want Alpha Vantage or Polygon.io.

# Alpha Vantage API key (https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_API_KEY=YOUR_ALPHA_VANTAGE_KEY

# Polygon.io API key (https://polygon.io/dashboard)
POLYGON_API_KEY=YOUR_POLYGON_KEY
