# ============================================================
# Apex Algo Trading Engine — Environment Configuration
# ============================================================
# Copy this file to .env and customize:
#   cp .env.example .env
#
# NOTE: .env is in .gitignore — never commit real keys.

# --- Data Source API Keys ---
# Yahoo Finance is free and enabled by default.
# Uncomment and set these for premium data sources.
#ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
#POLYGON_API_KEY=your_polygon_key

# --- Risk Management ---
# Max % of total capital allocated to a single trade (default: 0.02 = 2%)
MAX_POSITION_SIZE_PCT=0.02

# Stop trading if daily P&L drawdown exceeds this % (default: 0.05 = 5%)
MAX_DAILY_DRAWDOWN_PCT=0.05

# Leverage multiplier. 1.0 = no leverage (default). Set >1 for margin.
MAX_LEVERAGE=1.0

# Stop-loss distance as a multiple of Average True Range (default: 2.0)
STOP_LOSS_ATR_MULTIPLIER=2.0

# Take-profit distance as a multiple of Average True Range (default: 3.0)
TAKE_PROFIT_ATR_MULTIPLIER=3.0

# --- Paper Trading ---
# Starting simulated account balance (default: 100000)
PAPER_STARTING_CAPITAL=100000

# Commission per round-turn trade (default: 2.50)
PAPER_COMMISSION_PER_TRADE=2.50
